# ── Base de datos ─────────────────────────────────────────────
DB_HOST=tu_host_mysql
DB_PORT=3306
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=fittrack

# ── Autenticación ─────────────────────────────────────────────
# Genera una clave larga y aleatoria, por ejemplo con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga
SESSION_SECRET=cambia_esto_por_otra_clave_secreta

# ── Servidor ──────────────────────────────────────────────────
PORT=3000

# ── Strava (opcional) ─────────────────────────────────────────
# Crea tu app en: https://www.strava.com/settings/api
# Callback domain: localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/actividades/strava/callback