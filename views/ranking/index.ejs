<%- include('../partials/header') %>
<div class="page-header">
  <div>
    <h2>Ranking</h2>
    <p>Top 20 usuarios más activos</p>
  </div>
</div>

<div class="ranking-table">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Usuario</th>
        <th>Sesiones</th>
        <th>Distancia</th>
        <th>Calorías</th>
      </tr>
    </thead>
    <tbody>
      <% ranking.forEach((u, i) => { %>
        <tr class="<%= u.id === usuario.id ? 'fila-propia' : '' %>">
          <td>
            <span class="rank-num <%= i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '' %>">
              <%= i === 0 ? '1' : i === 1 ? '2' : i === 2 ? '3' : i + 1 %>
            </span>
          </td>
          <td>
            <span class="rank-user">
              <%= u.nombre %>
              <% if (u.id === usuario.id) { %><span class="you">tú</span><% } %>
            </span>
          </td>
          <td><%= u.dataValues.total_sesiones || 0 %></td>
          <td><%= parseFloat(u.dataValues.total_distancia || 0).toFixed(1) %> km</td>
          <td><%= parseInt(u.dataValues.total_calorias || 0).toLocaleString() %> kcal</td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
