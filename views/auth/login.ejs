<%- include('../partials/header') %>
<div class="auth-page">
    <div class="auth-card">
        <h2>Bienvenido</h2>
        <p>Inicia sesión en tu cuenta FitTrack</p>
        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" form="login-form" required autocomplete="email">
        </div>
        <div class="form-group">
            <label>Contraseña</label>
            <input type="password" name="password" form="login-form" required autocomplete="current-password">
        </div>
        <form id="login-form" action="/auth/login" method="POST">
            <button type="submit" class="btn btn-red">Iniciar sesión</button>
        </form>
        <p class="auth-footer">¿No tienes cuenta? <a href="/auth/registro">Regístrate</a></p>
    </div>
</div>
<%- include('../partials/footer') %>
