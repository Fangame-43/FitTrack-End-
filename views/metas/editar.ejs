<%- include('../partials/header') %>
<h2>Editar meta</h2>
<form action="/metas/<%= meta.id %>/editar" method="POST">
    <div class="form-group">
        <label>Tipo de meta</label>
        <select name="tipo" required>
            <% ['distancia_total','calorias_totales','sesiones','tiempo_total','peso'].forEach(t => { %>
                <option value="<%= t %>" <%= meta.tipo === t ? 'selected' : '' %>><%= t.replace('_', ' ') %></option>
            <% }) %>
        </select>
    </div>
    <div class="form-group">
        <label>Valor objetivo</label>
        <input type="number" name="valor_esperado" value="<%= meta.valor_esperado %>" step="0.01" min="0.01" required>
    </div>
    <div class="form-group">
        <label>Fecha de inicio</label>
        <input type="date" name="fecha_inicio" value="<%= meta.fecha_inicio %>" required>
    </div>
    <div class="form-group">
        <label>Fecha de fin</label>
        <input type="date" name="fecha_fin" value="<%= meta.fecha_fin %>" required>
    </div>
    <button type="submit">Actualizar</button>
    <a href="/metas">Cancelar</a>
</form>
<%- include('../partials/footer') %>
